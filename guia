        .tip-text {
            font-size: 0.82rem;
            color: var(--gris-claro);
            line-height: 1.5;
            font-family: Arial, sans-serif;
        }

        /* ===== FOOTER ===== */
        .footer {
            background: var(--negro-pizarra);
            color: rgba(255,255,255,0.5);
            padding: 48px 20px;
            text-align: center;
